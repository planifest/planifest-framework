#!/usr/bin/env bash
# Planifest commit-msg hook (REQ-023, ADR-008)
#
# Validates commit messages against commit-standards.md.
# Exits 1 (blocks the commit) on any violation.
# Use git commit --no-verify to bypass intentionally.
#
# Installed automatically by setup.sh via git config core.hooksPath.

COMMIT_MSG_FILE="$1"
COMMIT_MSG=$(cat "$COMMIT_MSG_FILE")
SUBJECT=$(echo "$COMMIT_MSG" | head -n1)
WARNINGS=()

# ── Rule 1: No AI attribution ──────────────────────────────────────────────
AI_PATTERNS=(
  "[Cc]o-[Aa]uthored-[Bb]y:.*[Cc]laude"
  "[Cc]o-[Aa]uthored-[Bb]y:.*[Cc]opilot"
  "[Cc]o-[Aa]uthored-[Bb]y:.*[Cc]ursor"
  "[Cc]o-[Aa]uthored-[Bb]y:.*[Ww]indsurf"
  "[Cc]o-[Aa]uthored-[Bb]y:.*[Cc]line"
  "[Cc]o-[Aa]uthored-[Bb]y:.*[Aa]nthrop"
  "[Cc]o-[Aa]uthored-[Bb]y:.*[Oo]pen[Aa][Ii]"
  "[Cc]o-[Aa]uthored-[Bb]y:.*[Gg]emini"
  "co-developed with"
  "AI-assisted"
  "LLM-generated"
  "[Cc]laude helped"
  "generated by Claude"
  "generated by Copilot"
)
for pattern in "${AI_PATTERNS[@]}"; do
  if echo "$COMMIT_MSG" | grep -qiE "$pattern"; then
    WARNINGS+=("No AI attribution: remove AI tool or model references from commit messages (commit-standards.md §3)")
    break
  fi
done

# ── Rule 2: No affirmatory language ───────────────────────────────────────
AFFIRMATORY_PATTERNS=(
  "^[Dd]one\.?!?"
  "^[Ff]ixed\.?!?"
  "[Ww]orking now"
  "[Aa]ll done"
  "[Ff]inally works"
  "[Ll]ooks good"
)
for pattern in "${AFFIRMATORY_PATTERNS[@]}"; do
  if echo "$SUBJECT" | grep -qiE "$pattern"; then
    WARNINGS+=("No affirmatory language: keep messages objective and scope-focused (commit-standards.md §4)")
    break
  fi
done

# ── Rule 3: Subject line length ───────────────────────────────────────────
SUBJECT_LEN=${#SUBJECT}
if [ "$SUBJECT_LEN" -gt 72 ]; then
  WARNINGS+=("Subject line is ${SUBJECT_LEN} chars (max 72) — truncate to: \"${SUBJECT:0:69}...\" (commit-standards.md §1)")
fi

# ── Print violations and block ─────────────────────────────────────────────
if [ "${#WARNINGS[@]}" -gt 0 ]; then
  echo ""
  echo "  [Planifest] Commit blocked — commit-standards.md violations:"
  for warning in "${WARNINGS[@]}"; do
    echo "  ✖  $warning"
  done
  echo ""
  echo "  Fix the message and retry, or use git commit --no-verify to bypass."
  echo ""
  exit 1
fi

exit 0
